# ─────────────────────────────────────────────────────────
#  Cookies Grandma — Backend Environment Variables
#  Copy to .env and fill in real values
# ─────────────────────────────────────────────────────────

PORT=3000
NODE_ENV=development

# PostgreSQL — Render provides this automatically
DATABASE_URL=postgresql://user:password@host:5432/cookies_grandma

# Frontend URL (your Vercel deployment URL)
FRONTEND_URL=https://cookies-grandma.vercel.app

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_string_64_chars_min
JWT_EXPIRES_IN=7d

# Admin default credentials (change after first login!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=cookiesgrandma2025

# Email (Gmail — use App Password, NOT your login password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-16-char-app-password
EMAIL_FROM=Cookies Grandma <your-email@gmail.com>

# WhatsApp Business Number (without +)
WA_NUMBER=6281234567890

# Midtrans Payment Gateway
# Keys from: https://dashboard.midtrans.com → Settings → Access Keys
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_SERVER_KEY=SB-Mid-server-YOUR_KEY_HERE
MIDTRANS_CLIENT_KEY=SB-Mid-client-YOUR_KEY_HERE

# Product Prices (IDR)
PRICE_NASTAR=95000
PRICE_KASTANGEL=95000
PRICE_GIFT_WRAP=15000
PRICE_HAMPER_BOX=35000
